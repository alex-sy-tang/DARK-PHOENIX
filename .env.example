# Dark Phoenix — example environment file
#
# Copy this file to `.env` (in this same project root) and fill in real values.
# The `.env` file is gitignored.
#
# This is the single source of environment variables for the whole project:
#   • The Next.js frontend loads it via `@next/env` from
#     ai-podcast-clipper-frontend/next.config.js (loadEnvConfig('..')).
#   • The Modal Python backend loads it via python-dotenv from
#     ai-podcast-clipper-backend/setup_modal_secret.py (load_dotenv("../.env")).
#
# When you add a new variable here, also update
# ai-podcast-clipper-frontend/src/env.js so the runtime validation knows about it.

# --- NextAuth ---------------------------------------------------------------
# Generate a fresh secret with: npx auth secret
AUTH_SECRET=""

# --- Discord OAuth ----------------------------------------------------------
# Create an app at https://discord.com/developers/applications
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# --- Database (Supabase Postgres) -------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# URL-encode special characters in the password (e.g. @ -> %40).
DATABASE_URL=""

# --- AWS S3 (video storage) -------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
S3_BUCKET_NAME=""

# --- Modal backend (video processing endpoint) -----------------------------
# Public Modal endpoint URL emitted when you deploy the backend.
PROCESS_VIDEO_ENDPOINT=""
# Shared bearer token used by the frontend to authenticate to Modal.
PROCESS_VIDEO_ENDPOINT_AUTH=""
# Public Modal endpoint URL for the lightweight YouTube download function.
# Also authenticated with PROCESS_VIDEO_ENDPOINT_AUTH (same bearer token/AUTH_TOKEN secret).
YOUTUBE_DOWNLOAD_ENDPOINT=""

# --- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SMALL_CREDIT_PACK=""
STRIPE_MEDIUM_CREDIT_PACK=""
STRIPE_LARGE_CREDIT_PACK=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Gemini AI (consumed by the Modal backend) -----------------------------
GEMINI_API_KEY=""

# --- App ---------------------------------------------------------------------
BASE_URL="http://localhost:3000"
